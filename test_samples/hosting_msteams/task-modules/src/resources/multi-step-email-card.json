{
  "type": "AdaptiveCard",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "text": "Email, {{name}}!",
      "size": "Large",
      "weight": "Bolder"
    },
    {
      "type": "Input.Text",
      "id": "email",
      "label": "Email",
      "isRequired": true,
      "placeholder": "Enter your email"
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Submit",
      "data": {
        "verb": "multi_step_form_submit_email",
        "name": "{{name}}"
      }
    }
  ]
}
