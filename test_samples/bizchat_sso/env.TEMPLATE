# Rename this file to .env and fill in your values.

# Azure Bot registration credentials (service connection used for outbound calls)
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTID=<your-bot-app-client-id>
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTSECRET=<your-bot-app-client-secret>
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__TENANTID=<your-tenant-id>

# Azure Bot OAuth connection name (configured in the Azure portal under the bot resource)
# This connection is used for the Graph SSO flow.
AGENTAPPLICATION__USERAUTHORIZATION__HANDLERS__GRAPH__SETTINGS__AZUREBOTOAUTHCONNECTIONNAME=<oauth-connection-name>
# OBO connection name – can be the same as the connection above or a separate OBO-enabled connection
AGENTAPPLICATION__USERAUTHORIZATION__HANDLERS__GRAPH__SETTINGS__OBOCONNECTIONNAME=<oauth-connection-name>
