# Entra ID Auth Sidecar connection (credential-free for OUTBOUND tokens).
# No CLIENTSECRET / certificate is required: the sidecar owns all credentials
# used to acquire outbound tokens.
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__AUTHTYPE=EntraAuthSideCar
# CLIENTID is the agent's Entra app (blueprint) id. Used both as the inbound-token
# audience (when validation is enabled) and as the blueprint app id for the sidecar.
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTID=blueprint-app-id
# TENANTID is used for INBOUND channel-token validation (JWKS/issuer lookup).
# Required only when TOKENVALIDATION__ENABLED=true (see below).
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__TENANTID=tenant-id
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__SERVICE_NAME=botframework
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__BLUEPRINT_SERVICE_NAME=agenticblueprint
# Channel-callback scope. Mirrors the C# sample: the Azure Bot Service resource.
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__SCOPES__0=5a807f24-c9de-44ee-a3a7-329e88a00ffc/.default

# Optional: sidecar endpoint. Resolution order: SIDECAR_URL env var > this > default.
# The resolved host must be loopback/private unless BYPASS_LOCAL_NETWORK_RESTRICTION is set.
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__SIDECAR_BASE_URL=http://localhost:5178

CONNECTIONSMAP__0__SERVICEURL=*
CONNECTIONSMAP__0__CONNECTION=SERVICE_CONNECTION

# Agentic user-authorization handler (mirrors the C# sample's "agentic" handler).
AGENTAPPLICATION__USERAUTHORIZATION__HANDLERS__AGENTIC__SETTINGS__TYPE=AgenticUserAuthorization
AGENTAPPLICATION__USERAUTHORIZATION__HANDLERS__AGENTIC__SETTINGS__SCOPES=https://graph.microsoft.com/.default
AGENTAPPLICATION__USERAUTHORIZATION__HANDLERS__AGENTIC__SETTINGS__ALT_BLUEPRINT_NAME=SERVICE_CONNECTION

# Inbound channel-token validation (parity with the C# sample's "TokenValidation:Enabled").
# Default false so the sample runs locally against the sidecar without a real
# tenant/app registration. Set true (with a real CLIENTID/TENANTID) for non-local
# deployments; when true, TENANTID above is required for JWKS/issuer lookup.
TOKENVALIDATION__ENABLED=false

# Takes precedence over SIDECAR_BASE_URL when set.
# SIDECAR_URL=http://localhost:5178
